# NSLS Auth — OIDC configuration
# Copy to .env (or your platform's secret manager) and fill in values.
# Never commit a real .env to git.

# Issuer URL — same for every NSLS app.
OIDC_ISSUER_URL=https://auth.nsls.org

# Client ID assigned to your app at registration.
# Example: thesociety-web, app-nsls-org, internal-admin
OIDC_CLIENT_ID=your-client-id

# Client secret. Required for application_type: web. Omit for native apps.
# The current Admin Portal asks the operator to paste in a secret rather than
# auto-generating one. The operator generates it locally with:
#   openssl rand -hex 32
# then shares it back to the app team via 1Password / Bitwarden — never chat.
OIDC_CLIENT_SECRET=provided-by-admin-after-registration

# Exact callback URL registered on the client. Must match exactly — query params, trailing slash, scheme.
OIDC_REDIRECT_URI=https://your-app.example.com/auth/callback

# Where the browser lands after RP-initiated logout. Must be a registered post_logout_redirect_uri.
# Point this at your app's login-start route for branded re-entry.
OIDC_POST_LOGOUT_REDIRECT_URI=https://your-app.example.com/auth/login?status=signed_out

# Space-separated scopes. Add `roles` only if the app makes admin/staff decisions.
# Add `offline_access` only if the app needs refresh tokens.
OIDC_SCOPES=openid profile email

# Local session secret — used to sign your app's own session cookie.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=replace-with-a-long-random-secret

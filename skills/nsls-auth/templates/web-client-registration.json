    "footerLogoUri": "https://your-app.example.com/static/footer-logo.png",
    "footerLogoAlt": "NSLS"
  },
  "client_secret": "PASTE-OUTPUT-OF-openssl-rand-hex-32-AT-REGISTRATION-TIME-DO-NOT-COMMIT",

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExpertVerdict",
  "description": "One expert's single-sample verdict over all 16 rubric sub-checks (Stage 2 blind, repeated 3x; Stage 3 revised). Feeds scorecard.mjs.",
  "type": "object",
  "required": ["expert", "sample", "dimensions"],
  "additionalProperties": false,
  "properties": {
    "expert": { "type": "string", "enum": ["UX Designer", "Educational Designer", "Copywriter", "Product/Engagement Strategist"] },
    "sample": { "type": "integer", "description": "1..3 — which of the 3 independent samples" },
    "dimensions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["dim", "subChecks"],
        "additionalProperties": false,
        "properties": {
          "dim": { "type": "string", "enum": ["value", "pacing", "copy", "fit"] },
          "subChecks": {
            "type": "array",
            "minItems": 4,
            "maxItems": 4,
            "items": {
              "type": "object",
              "required": ["key", "verdict", "evidenceScreen", "rationale"],
              "additionalProperties": false,
              "properties": {
                "key": { "type": "string", "enum": ["a", "b", "c", "d"] },
                "verdict": { "type": "string", "enum": ["MET", "UNMET"] },
                "evidenceScreen": { "type": "integer", "description": "screen index cited as evidence" },
                "rationale": { "type": "string", "description": "justification written BEFORE the verdict; ignore copy length" }
              }
            }
          }
        }
      }
    }
  }
}

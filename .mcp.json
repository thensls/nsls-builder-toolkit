{
  "mcpServers": {
    "signal": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp-servers/signal/signal-mcp.js"
      ]
    },
    "society-studio": {
      "type": "http",
      "url": "https://studio.nsls.org/api/mcp",
      "headers": {
        "Authorization": "Bearer ${STUDIO_MCP_TOKEN}"
      }
    }
  }
}

{
  "SessionStart": [
    {
      "matcher": "startup|resume",
      "hooks": [
        {
          "type": "command",
          "command": "python3 -c \"exec(open(__import__('pathlib').Path.home() / '.claude/local-plugins/nsls-builder-toolkit/hooks/session-start.py').read())\""
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "bash $HOME/.claude/local-plugins/nsls-builder-toolkit/hooks/skill-event.sh",
          "timeout": 5
        }
      ]
    }
  ]
}
